# Environment Variables — CarePoint Backend
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.

# ─── Server ────────────────────────────────────────────────────────────────────
PORT=3000

# Allowed origin(s) for CORS. Use a comma-separated list for multiple origins.
# Example: http://localhost:5500,https://carepoint.com
CORS_ORIGIN=http://localhost:5500

# ─── Supabase ──────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── Rate Limiting ─────────────────────────────────────────────────────────────
# Max requests per window per IP (defaults apply if not set)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
